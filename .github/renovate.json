{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":disableDependencyDashboard"
  ],
  "ignorePresets": [
    ":maintainLockFilesWeekly"
  ],
  "ignorePaths": [
    ".kokoro/**"
  ],
  "packageRules":[
    {
      "matchPackageNames": [
        "dotnet-sdk"
      ],
      "allowedVersions": "<9.0.0",
      "minimumReleaseAge": "7 days"
    }
  ],
  "schedule": ["before 8am"],
  "timezone": "Europe/London"
}
